# Knowledge Node - 环境变量配置
# 复制此文件为 .env 并根据需要修改

# ============== 数据库配置 ==============
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=knowledge_node
POSTGRES_PORT=5433

# ============== 后端配置 ==============
BACKEND_PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knowledge_node?schema=public

# ============== 前端配置 ==============
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_strong_secret
VENUS_API_KEY=your_venus_api_token_here

# ============== CORS 配置 ==============
CORS_ORIGIN=http://localhost:3000
