generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  passwordHash   String
  name           String?
  avatar         String?
  isInitialized  Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  nodes          Node[]
  tagTemplates   TagTemplate[]    // 创建的标签模版（管理员/UGC创建者）
  tagLibrary     UserTagLibrary[] // 用户订阅的标签库
  settings       UserSetting[]

  @@map("users")
}

model Node {
  id          String       @id @default(cuid())
  userId      String
  parentId    String?
  content     String       @default("")
  nodeType    String       @default("text")
  nodeRole    String       @default("normal")
  supertagId  String?
  payload     Json         @default("{}")
  fields      Json         @default("{}")
  tags        String[]     @default([])
  references  Json?
  sortOrder   Int          @default(0)
  isCollapsed Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  parent      Node?        @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Node[]       @relation("NodeHierarchy")
  supertag    TagTemplate? @relation(fields: [supertagId], references: [id])
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([parentId])
  @@index([supertagId])
  @@index([nodeType])
  @@index([createdAt])
  @@index([userId, nodeRole, parentId])
  @@index([userId, parentId, sortOrder])
  @@map("nodes")
}

// 标签模版表 - 系统预置标签库
// v3.4: 移除 parentId 继承关系，移除 categoryId 分类关系
model TagTemplate {
  id               String           @id @default(cuid())
  name             String
  color            String           @default("#6366F1")
  icon             String?
  description      String?
  fieldDefinitions Json             @default("[]")
  isGlobalDefault  Boolean          @default(true)   // 系统预置标识，当前全为 true
  creatorId        String?                           // 预留 UGC 创建者 ID
  status           String           @default("active") // active/deprecated/draft
  order            Int              @default(0)
  templateContent  Json?                             // 默认内容模版
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // 关联关系
  nodes            Node[]
  creator          User?            @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  userLibraries    UserTagLibrary[]

  @@index([isGlobalDefault, status])
  @@index([creatorId])
  @@map("tag_templates")
}

// 用户标签库映射表 - 预留给未来 UGC 模版市场
model UserTagLibrary {
  id            String      @id @default(cuid())
  userId        String
  tagTemplateId String
  isActive      Boolean     @default(true)
  addedAt       DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tagTemplate   TagTemplate @relation(fields: [tagTemplateId], references: [id], onDelete: Cascade)

  @@unique([userId, tagTemplateId])
  @@index([userId])
  @@index([tagTemplateId])
  @@map("user_tag_library")
}

// v3.4: Category 模型已移除，标签不再按分类组织

model UserSetting {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@map("user_settings")
}
