# 数据库配置
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/knowledge_node?schema=public"

# 服务配置
PORT=4000
NODE_ENV=development

# CORS 配置
CORS_ORIGIN=http://localhost:3000

# ============== AI 服务配置 ==============
# 优先级：GEMINI > VENUS > OPENAI
# 只需配置其中一种即可

# 方式一：Gemini API（推荐）
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash"

# 方式二：Venus API（腾讯内部）
# VENUS_API_KEY="your-venus-api-key"
# VENUS_API_URL="http://v2.open.venus.oa.com/llmproxy"
# VENUS_MODEL="gemini-2.5-flash"

# 方式三：OpenAI API
# OPENAI_API_KEY="sk-xxx"
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_MODEL="gpt-4o-mini"

# 说明：
# 生产环境请使用 docker-compose 注入 DATABASE_URL 与 CORS_ORIGIN，避免硬编码本地地址
