generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  passwordHash   String
  name           String?
  avatar         String?
  isInitialized  Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  nodes          Node[]
  tagTemplates   TagTemplate[]
  tagLibrary     UserTagLibrary[]
  settings       UserSetting[]

  @@map("users")
}

model Node {
  id          String       @id @default(cuid())
  logicalId   String
  userId      String
  parentId    String?
  content     String       @default("")
  nodeType    String       @default("text")
  nodeRole    String       @default("normal")
  supertagId  String?
  payload     Json         @default("{}")
  fields      Json         @default("{}")
  tags        String[]     @default([])
  references  Json?
  sortOrder   Int          @default(0)
  isCollapsed Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  parent      Node?        @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Node[]       @relation("NodeHierarchy")
  supertag    TagTemplate? @relation(fields: [supertagId], references: [id])
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, logicalId])
  @@index([userId, logicalId])
  @@index([parentId])
  @@index([supertagId])
  @@index([nodeType])
  @@index([createdAt])
  @@index([userId, nodeRole, parentId])
  @@index([userId, parentId, sortOrder])
  edgesAsSource  NetworkEdge[] @relation("EdgeSource")
  edgesAsTarget  NetworkEdge[] @relation("EdgeTarget")

  @@map("nodes")
}

// 拓扑边表：节点间多对多有向关系（DAG）
// 切边后树结构由 CONTAINS 表达，BLOCKS/RESOLVES 表达业务依赖
enum EdgeType {
  CONTAINS  // 包含：大纲父子
  BLOCKS    // 阻塞：执行先决
  RESOLVES  // 解决：灵感→卡点
  MENTION   // 提及：source 在内容/字段中引用 target
}

model NetworkEdge {
  id           String   @id @default(cuid())
  sourceNodeId String
  targetNodeId String
  edgeType     EdgeType
  createdAt    DateTime @default(now())

  sourceNode Node @relation("EdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode Node @relation("EdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@unique([sourceNodeId, targetNodeId, edgeType])
  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@index([edgeType])
  @@map("network_edges")
}

// 标签模版表 - 系统预置标签库
// v3.4: 移除 parentId 继承关系，移除 categoryId 分类关系
// v3.6: 新增 viewConfig 视图配置字段
// v4.2: 新增 category 实体/行动双轨（entity | action）
model TagTemplate {
  id               String           @id @default(cuid())
  name             String
  color            String           @default("#6366F1")
  icon             String?
  description      String?
  category         String?          // v4.2: 'entity' | 'action' 实体标签 / 行动标签
  fieldDefinitions Json             @default("[]")
  viewConfig       Json?            // v3.6: 视图配置（声明式驱动 Pinned 页面渲染）
  isGlobalDefault  Boolean          @default(true)
  creatorId        String?
  status           String           @default("active")
  order            Int              @default(0)
  templateContent  Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  nodes            Node[]
  creator          User?            @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  userLibraries    UserTagLibrary[]

  @@index([isGlobalDefault, status])
  @@index([creatorId])
  @@map("tag_templates")
}

// 用户标签库映射表 - 预留给未来 UGC 模版市场
model UserTagLibrary {
  id            String      @id @default(cuid())
  userId        String
  tagTemplateId String
  isActive      Boolean     @default(true)
  addedAt       DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tagTemplate   TagTemplate @relation(fields: [tagTemplateId], references: [id], onDelete: Cascade)

  @@unique([userId, tagTemplateId])
  @@index([userId])
  @@index([tagTemplateId])
  @@map("user_tag_library")
}

model UserSetting {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@map("user_settings")
}
