{
  "$schema": "./preset-tags.schema.json",
  "description": "预置标签 v4.3 - 新增地点/概念/RabbitHole，并统一 AI 描述格式（定义+适用场景+AI触发建议）",
  "tags": [
    {
      "name": "事件",
      "category": "entity",
      "color": "#3B82F6",
      "icon": "📅",
      "description": "时间锚定的事件记录。捕捉发生在特定时间的活动和经历，无状态流转。适用于会议、约会、出行、里程碑。AI应在用户提及具体日期、时间或日程安排时建议此标签。",
      "order": 1,
      "fieldDefinitions": [
        {
          "id": "event_date",
          "key": "event_date",
          "name": "时间日期",
          "type": "date"
        },
        {
          "id": "event_type",
          "key": "event_type",
          "name": "事件类型",
          "type": "select",
          "options": ["会议", "沟通", "出行", "专注"]
        }
      ],
      "isGlobalDefault": true,
      "status": "active"
    },
    {
      "name": "项目",
      "category": "entity",
      "color": "#8B5CF6",
      "icon": "📦",
      "description": "目标驱动的工作容器。组织围绕特定目标展开的任务和资源，无状态流转。适用于产品迭代、学习计划、跨周期协作。AI应在用户描述多步骤目标或需要协调多方资源时建议此标签。",
      "order": 2,
      "fieldDefinitions": [
        {
          "id": "project_status",
          "key": "project_status",
          "name": "项目状态",
          "type": "select",
          "options": ["规划", "执行", "复盘", "归档"]
        },
        {
          "id": "project_owner",
          "key": "project_owner",
          "name": "项目负责人",
          "type": "reference",
          "targetTagName": "人物",
          "multiple": true
        }
      ],
      "isGlobalDefault": true,
      "status": "active"
    },
    {
      "name": "人物",
      "category": "entity",
      "color": "#10B981",
      "icon": "👤",
      "description": "人际关系锚点。记录与特定人物相关的角色、联系方式和互动背景，无状态流转。适用于同事、客户、朋友、专家。AI应在用户提及人名或描述与他人的关系时建议此标签。",
      "order": 3,
      "fieldDefinitions": [
        {
          "id": "person_role",
          "key": "person_role",
          "name": "角色",
          "type": "text"
        }
      ],
      "isGlobalDefault": true,
      "status": "active"
    },
    {
      "name": "Source",
      "category": "entity",
      "color": "#F59E0B",
      "icon": "📚",
      "description": "外部信息源引用。标记文章、书籍、视频、播客等外部知识来源的链接与摘要，无状态流转。AI应在用户粘贴 URL、引用外部内容或标注出处时建议此标签。",
      "order": 4,
      "fieldDefinitions": [
        {
          "id": "source_url",
          "key": "source_url",
          "name": "URL",
          "type": "text"
        },
        {
          "id": "source_note",
          "key": "source_note",
          "name": "信息说明",
          "type": "text"
        }
      ],
      "isGlobalDefault": true,
      "status": "active"
    },
    {
      "name": "地点",
      "category": "entity",
      "color": "#0EA5E9",
      "icon": "🗺️",
      "description": "地理坐标锚点。标记具体地理位置，捕捉与地点相关的记忆、体验和实用信息，无状态流转。适用于旅行目的地、常去场所、待探索地点。AI应在用户提及地名、地址或坐标时建议此标签。",
      "order": 5,
      "fieldDefinitions": [
        {
          "id": "place_type",
          "key": "place_type",
          "name": "地点类型",
          "type": "select",
          "options": ["餐厅", "景点", "住宿", "交通枢纽", "工作场所", "生活", "其他"]
        },
        {
          "id": "place_coordinates",
          "key": "place_coordinates",
          "name": "坐标/地址",
          "type": "text"
        },
        {
          "id": "place_visited_at",
          "key": "place_visited_at",
          "name": "到访时间",
          "type": "date"
        },
        {
          "id": "place_rating",
          "key": "place_rating",
          "name": "评分",
          "type": "select",
          "options": ["1", "2", "3", "4", "5"]
        }
      ],
      "isGlobalDefault": true,
      "status": "active"
    },
    {
      "name": "概念",
      "category": "entity",
      "color": "#7C3AED",
      "icon": "🧠",
      "description": "长期积累的知识簇。标记需要反复咀嚼、逐步深化理解的抽象概念或理论框架，无状态流转。适用于专业术语、心智模型、方法论、底层原理。AI应在用户记录定义性知识、理论解释或跨领域抽象概念时建议此标签。",
      "order": 6,
      "fieldDefinitions": [
        {
          "id": "concept_domain",
          "key": "concept_domain",
          "name": "所属领域",
          "type": "text"
        },
        {
          "id": "concept_maturity",
          "key": "concept_maturity",
          "name": "理解程度",
          "type": "select",
          "options": ["初识", "熟悉", "精通"]
        },
        {
          "id": "concept_sources",
          "key": "concept_sources",
          "name": "信息来源",
          "type": "reference",
          "targetTagName": "Source",
          "multiple": true
        }
      ],
      "isGlobalDefault": true,
      "status": "active"
    },
    {
      "name": "todo",
      "category": "action",
      "color": "#EF4444",
      "icon": "♟️",
      "description": "可执行的原子任务。自带 Ready、Locked、Done 三态状态机，存在前置卡点时可自动锁定。适用于可明确定义完成条件的待办事项。AI应在用户表达要做、需要完成、应该执行等明确待办意图时建议此标签。",
      "order": 7,
      "fieldDefinitions": [
        {
          "id": "todo_status",
          "key": "todo_status",
          "name": "当前状态",
          "type": "status",
          "statusConfig": {
            "states": ["Ready", "Locked", "Done"],
            "initial": "Ready",
            "doneState": "Done",
            "blockedStates": ["Locked"],
            "unblockedStates": ["Ready"],
            "transitions": {
              "user_toggle": { "Ready": "Done", "Done": "Ready" },
              "add_blocker": { "Ready": "Locked" },
              "all_blockers_resolved": { "Locked": "Ready" }
            }
          }
        },
        {
          "id": "todo_deadline",
          "key": "todo_deadline",
          "name": "Deadline",
          "type": "date"
        },
        {
          "id": "todo_deps",
          "key": "todo_deps",
          "name": "前置依赖",
          "type": "reference",
          "targetTagNames": ["卡点", "todo"],
          "multiple": true
        }
      ],
      "isGlobalDefault": true,
      "status": "active"
    },
    {
      "name": "卡点",
      "category": "action",
      "color": "#EC4899",
      "icon": "🪢",
      "description": "阻塞任务推进的障碍。自带 Open、Resolved 状态机，解决后可解除相关任务阻塞。适用于依赖未满足、外部等待、关键困难。AI应在用户描述阻碍、卡住、等待条件时建议此标签。",
      "order": 8,
      "fieldDefinitions": [
        {
          "id": "blocker_status",
          "key": "blocker_status",
          "name": "当前状态",
          "type": "status",
          "statusConfig": {
            "states": ["Open", "Resolved"],
            "initial": "Open",
            "resolvedState": "Resolved",
            "transitions": {
              "user_toggle": { "Open": "Resolved", "Resolved": "Open" }
            }
          }
        },
        {
          "id": "blocker_priority",
          "key": "blocker_priority",
          "name": "优先级",
          "type": "select",
          "options": ["P0", "P1", "P2"]
        },
        {
          "id": "blocker_ideas",
          "key": "blocker_ideas",
          "name": "有效灵感",
          "type": "reference",
          "targetTagName": "灵感",
          "multiple": true
        }
      ],
      "isGlobalDefault": true,
      "status": "active"
    },
    {
      "name": "灵感",
      "category": "action",
      "color": "#F59E0B",
      "icon": "⚡",
      "description": "待验证的创意火花。自带孵化、已验证、已丢弃状态机，支持从想法到验证闭环。适用于突发想法、方案假设、创意联想。AI应在用户表达灵光一现、设想或探索性方案时建议此标签。",
      "order": 9,
      "fieldDefinitions": [
        {
          "id": "idea_status",
          "key": "idea_status",
          "name": "当前状态",
          "type": "status",
          "statusConfig": {
            "states": ["孵化", "已验证", "已丢弃"],
            "initial": "孵化",
            "transitions": {
              "user_toggle": { "孵化": "已验证", "已验证": "孵化", "已丢弃": "孵化" }
            }
          }
        },
        {
          "id": "idea_feasibility",
          "key": "idea_feasibility",
          "name": "可行性",
          "type": "select",
          "options": ["高", "中", "低"]
        },
        {
          "id": "idea_blockers",
          "key": "idea_blockers",
          "name": "关联卡点",
          "type": "reference",
          "targetTagName": "卡点",
          "multiple": true
        }
      ],
      "isGlobalDefault": true,
      "status": "active"
    },
    {
      "name": "快照",
      "category": "action",
      "color": "#6B7280",
      "icon": "📸",
      "description": "轻量级时刻标记。无额外字段与状态机，用于快速捕捉无需结构化管理的片段记录。适用于短笔记、随手记录、过渡信息。AI应在内容不匹配其他标签但用户仍希望快速标记时建议此标签。",
      "order": 10,
      "fieldDefinitions": [],
      "isGlobalDefault": true,
      "status": "active"
    },
    {
      "name": "RabbitHole",
      "category": "action",
      "color": "#6D28D9",
      "icon": "🕳️",
      "description": "深度研究主题。标记引发强烈好奇、需要持续投入的复杂问题，自带研究进度状态机。适用于技术难题、学术课题、长期兴趣深挖。AI应在用户表达以后要深挖、持续研究或复杂待探索主题时建议此标签。",
      "order": 11,
      "fieldDefinitions": [
        {
          "id": "rabbit_status",
          "key": "rabbit_status",
          "name": "研究状态",
          "type": "status",
          "statusConfig": {
            "states": ["发现", "挖掘中", "暂停", "挖透"],
            "initial": "发现",
            "doneState": "挖透",
            "blockedStates": ["暂停"],
            "unblockedStates": ["发现", "挖掘中"],
            "transitions": {
              "user_toggle": { "发现": "挖掘中", "挖掘中": "挖透", "挖透": "挖掘中" },
              "pause": { "挖掘中": "暂停" },
              "resume": { "暂停": "挖掘中" }
            }
          }
        },
        {
          "id": "rabbit_depth",
          "key": "rabbit_depth",
          "name": "目标深度",
          "type": "select",
          "options": ["浅尝辄止", "了解全貌", "系统掌握", "学术级深挖"]
        },
        {
          "id": "rabbit_time_budget",
          "key": "rabbit_time_budget",
          "name": "时间预算",
          "type": "select",
          "options": ["1小时", "半天", "1-3天", "1周+", "无上限"]
        },
        {
          "id": "rabbit_sources",
          "key": "rabbit_sources",
          "name": "参考资料",
          "type": "reference",
          "targetTagName": "Source",
          "multiple": true
        }
      ],
      "isGlobalDefault": true,
      "status": "active"
    }
  ]
}
